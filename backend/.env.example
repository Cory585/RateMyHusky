# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.

# CockroachDB
CRDB_DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
JWT_SECRET=

# Reddit API (https://www.reddit.com/prefs/apps — create a "script" type app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Format: <AppName>/1.0 by u/<your_reddit_username>
REDDIT_USER_AGENT=RateMyHusky/1.0 by u/YOUR_REDDIT_USERNAME
